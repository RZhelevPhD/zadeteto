# ZaDeteto Environment Variables
# Copy this file to .env and fill in the real values.

# Supabase
# Get both keys from: Supabase Dashboard → Project Settings → API Keys (new format)
# PUBLISHABLE key (sb_publishable_...) — safe for browser, protected by RLS. Replaces the old anon key.
# SECRET key      (sb_secret_...)      — server-only, bypasses RLS. NEVER expose to the browser or commit.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Google Sheets OAuth (download credentials.json from Google Cloud Console)
# No env var needed — uses credentials.json file in project root.

# Apify (for content intelligence pipeline — social media scraping)
# Get your token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=
