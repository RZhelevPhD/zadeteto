<!DOCTYPE html>
<html lang="bg">
<head>
<meta charset="UTF-8">
<title>За Детето • Директория</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
/* VARIABLES */
:root{ --purp-1:#f2e9ff; --purp-2:#d4b6ff; --purp-3:#a56cff; --mint-1:#eaffef; --mint-2:#d4ffd9; --mint-3:#2e994d; --std-1:#fff; --std-2:#f5f5f5; --std-3:#bdbdbd; --gray:#9c9c9c; --text:#222; }
/* GLOBAL */
html,body{ margin:0; font-family:'Inter',sans-serif; color:var(--text); background:url("https://assets.cdn.filesafe.space/c3cmUrbBhdgs54adfIYP/media/666136581848ae65069c5b9f.jpeg") center/cover fixed no-repeat; }
.directory-wrapper{ display:flex; gap:40px; align-items:flex-start; padding:24px; min-width:0; }
/* FILTERS */
#filters{ width:200px; position:sticky; top:24px; padding-right:24px; display:flex; flex-direction:column; gap:24px; }
.filter-section{width:100%}
.filter-title{ font:800 18px/1 'Inter'; margin:0 0 6px; cursor:pointer; display:flex; justify-content:space-between; align-items:center; }
.filter-title::after{content:"▼";font-size:12px;transition:.25s}
.filter-title.collapsed::after{transform:rotate(180deg)}
.filter-content.collapsed{display:none}
/* INPUTS */
.search-box input, .city-input input, .age-inputs input{ height:46px; padding:0 14px; font-size:16px; border:2px solid #bbb; border-radius:12px; background:#fff; width:100%; }
.age-inputs{display:flex;gap:12px}
.age-inputs input{appearance:textfield}
.age-inputs input::-webkit-inner-spin-button, .age-inputs input::-webkit-outer-spin-button{appearance:none;margin:0}
/* CATEGORY MENU */
#category-list{display:flex;flex-direction:column;gap:8px}
.cat-btn{ display:flex; align-items:center; justify-content:center; min-height:46px; padding:0 16px; border:2px solid #bbb; border-radius:12px; background:#fff; font:600 14px/1.2 'Inter'; cursor:pointer; transition:.15s; text-align:center; white-space:normal; }
.cat-btn[data-index="0"], .filter-chip[data-category-index="0"]{--col:hsl(240,100%,50%);color:var(--col)}
.cat-btn[data-index="1"], .filter-chip[data-category-index="1"]{--col:hsl(250,100%,50%);color:var(--col)}
.cat-btn[data-index="2"], .filter-chip[data-category-index="2"]{--col:hsl(260,100%,50%);color:var(--col)}
.cat-btn[data-index="3"], .filter-chip[data-category-index="3"]{--col:hsl(270,100%,50%);color:var(--col)}
.cat-btn[data-index="4"], .filter-chip[data-category-index="4"]{--col:hsl(280,100%,50%);color:var(--col)}
.cat-btn[data-index="5"], .filter-chip[data-category-index="5"]{--col:hsl(290,100%,50%);color:var(--col)}
.cat-btn[data-index="6"], .filter-chip[data-category-index="6"]{--col:hsl(300,100%,50%);color:var(--col)}
.subcat-panel{ position:absolute; background:#fff; box-shadow:0 2px 10px rgba(0,0,0,.1); z-index:10; display:none; padding:10px; flex-direction:column; gap:8px; border-radius:12px; max-width:200px; }
.filter-chip{ display:inline-flex; align-items:center; justify-content:center; min-height:46px; padding:0 16px; border:2px solid #bbb; border-radius:12px; background:#fff; font:600 14px/1.2 'Inter'; cursor:pointer; transition:.15s; text-align:center; white-space:normal; }
.filter-chip.include{ background:linear-gradient(#96f4a3,#63d977); color:#fff; border-color:var(--mint-3); }
.filter-chip.exclude{ background:linear-gradient(#ef8b8b,#d95757); color:#fff; border-color:#d95757; text-decoration:line-through; text-decoration-thickness:2.3px; }
/* TOGGLES */
.toggle-group{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.toggle-label{font-size:14px}
.toggle-switch{position:relative;display:inline-block;width:50px;height:24px}
.toggle-switch input{opacity:0;width:0;height:0}
.toggle-slider{ position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0; background-color:#ccc;transition:.4s;border-radius:24px }
.toggle-slider:before{ position:absolute;content:"";height:20px;width:20px;left:2px;bottom:2px; background-color:#fff;transition:.4s;border-radius:50% }
input:checked + .toggle-slider{background-color:var(--mint-3)}
input:checked + .toggle-slider:before{transform:translateX(26px)}
/* PILLS */
#active-filters{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
.active-filter-pill{ background:#ffe6e6;border-radius:8px;padding:4px 8px; font-size:12px;display:inline-flex;align-items:center;gap:6px;cursor:pointer }
.active-filter-pill .remove-filter{font-size:11px}
/* CARDS */
main{flex:1;min-width:0}
#card-container{ display:grid; grid-template-columns:repeat(auto-fit,400px); gap:24px;justify-content:center }
.card{ width:400px;min-height:510px;padding:18px;border-radius:16px; border:2px solid transparent;overflow:hidden; display:flex;flex-direction:column;align-items:center;text-align:center;gap:10px; background:linear-gradient(145deg,var(--bg1) 0%,var(--bg2) 100%); box-shadow:0 8px 20px rgb(0 0 0 / .15);transition:.3s;position:relative; will-change:transform; }
.card.tier-elite:hover, .card.tier-verified:hover{transform:translateY(-6px) rotate(var(--tilt));box-shadow:0 18px 40px rgb(0 0 0 / .28)}
.card.tier-elite, .card.tier-verified{animation:borderPulse 6s linear infinite}
@keyframes borderPulse{0%{border-color:transparent}50%{border-color:var(--ring)}100%{border-color:transparent}}
.tier-elite{--ring:var(--purp-3);--bg1:var(--purp-1);--bg2:var(--purp-2);--tilt:-2deg}
.tier-verified{--ring:var(--mint-3);--bg1:var(--mint-1);--bg2:var(--mint-2);--tilt: 2deg}
.tier-standard{--ring:var(--std-3);--bg1:var(--std-1);--bg2:var(--std-2);--tilt: 0deg}
.tier-free{--ring:transparent;--bg1:#fff; --bg2:#fff; --tilt: 0deg}
.logo-wrap{ width:160px;height:160px;border-radius:50%;overflow:hidden; border:6px solid var(--ring);display:flex;align-items:center;justify-content:center; position:relative;transition:.3s;will-change:transform }
.card.tier-elite:hover .logo-wrap, .card.tier-verified:hover .logo-wrap{transform:translateY(-10px)}
.card.tier-elite .logo-wrap::after, .card.tier-verified .logo-wrap::after{ content:"";position:absolute;inset:0;border-radius:50%; box-shadow:0 0 6px var(--ring);animation:logoGlow 4s ease-in-out infinite }
@keyframes logoGlow{50%{box-shadow:0 0 18px var(--ring)}}
.card-title{font:800 22px/1 'Inter';margin:0}
.city-line {font:700 18px/1 'Inter';margin:0 0 4px;color:#444}
.badge-row{display:flex;gap:6px;margin:3px 0}
.badge{padding:2px 8px;border-radius:10px;font:700 12px/1 'Inter';color:#fff}
.badge.elite{background:var(--purp-3)} .badge.verified{background:var(--mint-3)} .badge.standard{background:#c3c3c3;color:#222} .badge.free{background:var(--gray)} .badge.sop { background: #c43ae3; box-shadow: 0 0 8px #c43ae3; color: #fff; }
.tag-row{display:flex;flex-wrap:wrap;gap:4px;justify-content:center}
.tag{background:#f0f0f0;padding:3px 6px;border-radius:6px;font:13px/1 'Inter'}
.age-row{display:flex;flex-wrap:wrap;gap:4px;justify-content:center;margin-top:8px}
.age-pill{background:#e0e0e0;padding:3px 6px;border-radius:6px;font-size:12px;color:#333}
.cta-row{display:flex;gap:12px;justify-content:center;margin-top:14px}
.cta-btn{ flex:0 0 160px;height:40px;border-radius:8px;border:1px solid rgba(0,0,0,.1); display:flex;align-items:center;justify-content:center;font:700 14px/1 'Inter'; color:#fff;text-decoration:none;box-shadow:0 4px 8px rgba(0,0,0,.2), inset 0 1px 2px rgba(255,255,255,.3);transition:.25s }
.cta-btn:hover{transform:translateY(-2px)}
.btn-purple{background:var(--purp-3)} .btn-green {background:var(--mint-3)} .btn-silver{background:#c3c3c3;color:#222}
.reg-id{margin-top:auto;font-size:12px;color:#666}
.icon-bar{ display:flex;gap:18px;margin-top:8px; align-items:center;justify-content:center }
.icon-bar img{width:24px;height:24px;display:block}
/* MOBILE */
@media(max-width:767px){
  .directory-wrapper{flex-direction:column;padding:16px;gap:20px}
  #filters{ position:relative; padding-right:0; width:160px; }
  .subcat-panel{ max-width:150px; left:auto; right:16px; }
  #card-container{grid-template-columns:repeat(auto-fit,320px);gap:16px}
  .card{width:320px}
  .icon-bar{flex-wrap:wrap;gap:10px;justify-content:center}
  .cta-row{flex-wrap:wrap;gap:10px;justify-content:center}
  .cta-btn{flex:0 0 140px}
}
</style>
</head>
<body>
<div class="directory-wrapper">
  <aside id="filters">
    <div class="filter-section"><div class="search-box"><input id="search-text" placeholder="Търси услуга…" autocomplete="off"></div></div>
    <div class="filter-section age"><strong class="filter-title">Възраст</strong><div class="filter-content"><div class="age-inputs"><input id="age-from" type="number" placeholder="От … г." min="0" max="100"><input id="age-to" type="number" placeholder="До … г." min="0" max="100"></div></div></div>
    <div class="filter-section location"><strong class="filter-title">Населено място</strong><div class="filter-content city-input"><input id="city-search" placeholder="Въведи град…" list="city-list" autocomplete="off"><datalist id="city-list"></datalist></div></div>
    <div class="filter-section category"><strong class="filter-title">Категория</strong><div id="category-list"></div></div>
    <div class="filter-section"><strong class="filter-title">Други</strong><div class="filter-content"><div class="toggle-group"><label class="toggle-label">Подходящи за СОП</label><label class="toggle-switch"><input type="checkbox" id="sop-toggle"><span class="toggle-slider"></span></label></div><div class="toggle-group"><label class="toggle-label">Онлайн доставчици</label><label class="toggle-switch"><input type="checkbox" id="online-toggle"><span class="toggle-slider"></span></label></div></div></div>
    <div class="filter-section level"><strong class="filter-title">Вид абонамент</strong><div class="filter-content" id="tier-filter"></div></div>
  </aside>
  <main><div id="active-filters"></div><div id="card-container"><p>Зареждане...</p></div></main>
</div>
<div id="subcat-panel" class="subcat-panel"></div>

<script>
const subcategories = {
  "Стоки": ["За бебето", "Дрехи и обувки", "Играчки и игри", "Книги и помагала", "Храни", "Безопасност", "Джаджи", "Конзоли и PC"],
  "Учене и умения": ["Ясли и градини", "Училища", "Занимални", "Частни уроци", "STEM и програмиране", "Изкуства", "Езикови школи", "Музикални"],
  "Игри и забавления": ["Детски центрове", "Аркадни и VR", "Ресторанти", "Културни събития", "Театър", "Кино", "Други"],
  "Спорт и движение": ["Отборни", "Индивидуални", "Бойни изкуства", "Танци", "Плувни", "Outdoor"],
  "Тържества и събития": ["Центрове", "Аниматори", "Торти и кетъринг", "Фото и видео", "Декор", "Под наем"],
  "Специалисти": ["Детски психолози", "Логопеди", "Рехаблитатори", "Хранене и диетология", "Лекари", "Зъболекари"],
  "Домашна грижа": ["Детегледачки", "Домашен майстор"]
};
const categoryOrder = Object.keys(subcategories);
const tierVals = ["Доверен", "Проверен", "Стандартен", "Безплатен"];
const tierRank = { "Доверен": 0, "Проверен": 1, "Стандартен": 2, "Безплатен": 3 };
const icons = {
  phone: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/688e45fa1c1165ce6566161a.svg",
  email: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/688e45fa4f59c8f3b45fe711.svg",
  website: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/688e39f520486ca465431130.svg",
  facebook: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/688e45fa1c1165167a66161c.svg",
  instagram: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/688e45fa1c1165b73b661619.svg",
  tiktok: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/688e45fa4f59c80d255fe70e.svg",
  linkedin: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/688e45f958ee9ecb86249762.svg",
  x: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/68933def5016cb73723d0adc.svg",
  youtube: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/688e45fa4f59c8f88b5fe710.svg",
  maps: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/68933df9ed9c8fc6588920f1.svg",
  reviews: "https://storage.googleapis.com/msgsndr/cmgJfxv52lTcq2pgpVB3/media/68939cebd69f994a4dd582e5.png"
};
let searchTerm = "", cityTerm = "";
let ageFrom = null, ageTo = null;
const active = { level: { include: new Set(), exclude: new Set() }, category: { include: new Set(), exclude: new Set() } };
let sopFilter = null, onlineFilter = false;
let selectedCat = null;
let data = [];

function debounce(func, delay) { let timeout; return function (...args) { clearTimeout(timeout); timeout = setTimeout(() => func.apply(this, args), delay); }; }
function buildTierFilter() { const wrap = $("#tier-filter"); wrap.innerHTML = ""; tierVals.forEach(v => { const chip = document.createElement("div"); chip.className = "filter-chip"; chip.textContent = v; chip.dataset.type = "level"; chip.dataset.value = v; chip.onclick = chipToggle; wrap.appendChild(chip); }); }
function buildCategoryMaster() { const wrap = $("#category-list"); wrap.innerHTML = ""; categoryOrder.forEach((cat, idx) => { const btn = document.createElement("div"); btn.className = "cat-btn"; btn.textContent = cat; btn.dataset.index = idx; btn.onclick = ev => showSubcategories(ev.currentTarget, cat, idx); wrap.appendChild(btn); }); }
function updateCatMaster() { document.querySelectorAll("#category-list .cat-btn").forEach(b => b.classList.toggle("active", b.textContent === selectedCat)); }
function showSubcategories(btn, cat, idx) {
  selectedCat = cat; updateCatMaster();
  const panel = $("#subcat-panel"); panel.innerHTML = "";
  subcategories[cat].forEach(sub => { const chip = document.createElement("div"); chip.className = "filter-chip"; chip.textContent = sub; chip.dataset.type = "category"; chip.dataset.value = sub; chip.dataset.categoryIndex = idx; chip.onclick = chipToggle; panel.appendChild(chip); });
  const btnRect = btn.getBoundingClientRect(); const wrapRect = document.querySelector(".directory-wrapper").getBoundingClientRect();
  panel.style.left = `${btnRect.right - wrapRect.left + 12}px`; panel.style.top = `${btnRect.top - wrapRect.top}px`; panel.style.display = "flex";
  const widest = [...panel.children].reduce((w, c) => Math.max(w, c.scrollWidth), 0); [...panel.children].forEach(c => c.style.width = widest + "px"); updateChipStates();
}
function renderPills() {
  const box = $("#active-filters"); box.innerHTML = ""; let count = 0;
  if (ageFrom !== null || ageTo !== null) { count++; const pill = document.createElement("span"); pill.className = "active-filter-pill"; pill.innerHTML = `${ageFrom !== null ? `От ${ageFrom}` : ""}${ageFrom && ageTo ? "–" : ""}${ageTo !== null ? `До ${ageTo}` : ""} <span class="remove-filter">✕</span>`; pill.onclick = () => { ageFrom = ageTo = null; $("#age-from").value = ""; $("#age-to").value = ""; render(); }; box.appendChild(pill); }
  if (sopFilter) { count++; const p = document.createElement("span"); p.className = "active-filter-pill"; p.innerHTML = `СОП <span class="remove-filter">✕</span>`; p.onclick = () => { sopFilter = null; render(); }; box.appendChild(p); }
  if (onlineFilter) { count++; const p = document.createElement("span"); p.className = "active-filter-pill"; p.innerHTML = `Онлайн <span class="remove-filter">✕</span>`; p.onclick = () => { onlineFilter = false; render(); }; box.appendChild(p); }
  Object.entries(active).forEach(([type, { include, exclude }]) => { include.forEach(v => { count++; const p = document.createElement("span"); p.className = "active-filter-pill"; p.innerHTML = `${v} <span class="remove-filter">✕</span>`; p.onclick = () => { include.delete(v); updateChipStates(); render(); }; box.appendChild(p); }); exclude.forEach(v => { count++; const p = document.createElement("span"); p.className = "active-filter-pill"; p.innerHTML = `<s>${v}</s> <span class="remove-filter">✕</span>`; p.onclick = () => { exclude.delete(v); updateChipStates(); render(); }; box.appendChild(p); }); });
  if (count >= 2) { const clear = document.createElement("span"); clear.className = "active-filter-pill"; clear.innerHTML = `Изчисти <span class="remove-filter">✕</span>`; clear.onclick = () => { Object.values(active).forEach(o => { o.include.clear(); o.exclude.clear(); }); sopFilter = null; onlineFilter = false; updateChipStates(); render(); }; box.prepend(clear); }
}
function parseAgeGroup(s) { return s === "Тийнейджъри" ? [13, 19] : s.split("-").map(n => +n); }
function passAge(d) { if (ageFrom === null && ageTo === null) return true; const from = ageFrom ?? 0, to = ageTo ?? 100; return d.ageGroups.some(s => { const [a, b] = parseAgeGroup(s); return a <= to && b >= from; }); }
/* UPDATED FUNCTIONS FOR MULTIPLE CATEGORIES */
const passSearch = d => {
  if (!searchTerm) return true;
  const catStr = Array.isArray(d.categories) ? d.categories.join(" ") : d.categories;
  return [d.name, catStr, d.city, d.tier, ...d.services].join(" ").toLowerCase().includes(searchTerm);
};
const passCat = d => {
  if (active.category.include.size === 0 && active.category.exclude.size === 0) return true;
  // Handle both array and single string to be safe
  const cats = Array.isArray(d.categories) ? d.categories : [d.categories];
  // Show if ANY of the item's categories match the included filter
  const hasIncluded = active.category.include.size === 0 || cats.some(c => active.category.include.has(c));
  // Hide if ANY of the item's categories match the excluded filter
  const hasExcluded = cats.some(c => active.category.exclude.has(c));
  return hasIncluded && !hasExcluded;
};
const passLevel = d => !(active.level.include.size && !active.level.include.has(d.tier)) && !active.level.exclude.has(d.tier);
const passCity = d => !cityTerm || d.city.toLowerCase() === cityTerm;
const passSop = d => sopFilter === null || d.sop === sopFilter;
const passOnline = d => !onlineFilter || d.city === "Онлайн";
function icon(name, url) { return `<a href="${url}" target="_blank" rel="noopener"><img src="${icons[name]}" alt="${name}" loading="lazy"></a>`; }
function render() {
  renderPills();
  const list = data.filter(d => passSearch(d) && passCity(d) && passLevel(d) && passCat(d) && passAge(d) && passSop(d) && passOnline(d));
  updateCityList(list);
  const wrap = $("#card-container"); wrap.innerHTML = ""; const fragment = document.createDocumentFragment();
  list.sort((a, b) => tierRank[a.tier] - tierRank[b.tier] || a.name.localeCompare(b.name, 'bg')).forEach(d => {
    const tierClass = d.tier === "Доверен" ? "elite" : d.tier === "Проверен" ? "verified" : d.tier === "Стандартен" ? "standard" : "free";
    let ic = "";
    const allowedIcons = { "Доверен": ["phone", "email", "website", "facebook", "instagram", "tiktok", "linkedin", "x", "youtube", "maps", "reviews"], "Проверен": ["phone", "email", "website", "facebook", "instagram", "maps"], "Стандартен": ["phone", "email", "website", "facebook"], "Безплатен": ["phone", "email"] }[d.tier] || [];
    allowedIcons.forEach(k => { if(d[k] && d[k] !== "#") ic += icon(k, k === "phone" ? "tel:"+d[k] : k === "email" ? "mailto:"+d[k] : d[k]); });
    let cta = "";
    if (d.tier === "Доверен") cta = `<div class="cta-row"><a class="cta-btn btn-purple" href="${d.ctaUrl1 ?? '#'}" target="_blank">${d.ctaLabel1 ?? 'CTA1'}</a><a class="cta-btn btn-green" href="${d.ctaUrl2 ?? '#'}" target="_blank">${d.ctaLabel2 ?? 'CTA2'}</a></div>`;
    else if (d.tier === "Проверен" && d.ctaLabel) cta = `<div class="cta-row"><a class="cta-btn btn-green" href="${d.ctaUrl}" target="_blank">${d.ctaLabel}</a></div>`;
    else if (d.tier === "Стандартен" && d.ctaLabel) cta = `<div class="cta-row"><a class="cta-btn btn-silver" href="${d.ctaUrl}" target="_blank">${d.ctaLabel}</a></div>`;
    const ageBlock = d.tier !== "Безплатен" ? `<div class="age-row">${d.ageGroups.map(a => `<span class="age-pill">${a}</span>`).join("")}</div>` : "";
    const sopBadge = d.sop ? '<span class="badge sop">СОП</span>' : "";
    const limit = d.tier === "Доверен" ? 4 : d.tier === "Проверен" ? 3 : d.tier === "Стандартен" ? 2 : 1;
    const card = document.createElement("div"); card.className = `card tier-${tierClass}`;
    card.innerHTML = `<div class="logo-wrap"><img src="${d.logo}" alt="${d.name}" loading="lazy"></div><h3 class="card-title">${d.name}</h3><div class="city-line">${d.city}</div><div class="badge-row">${d.tier === "Доверен" ? '<span class="badge elite">ДОВЕРЕН</span><span class="badge verified">ПРОВЕРЕН</span>'+sopBadge : `<span class="badge ${tierClass}">${d.tier.toUpperCase()}</span>${sopBadge}`}</div><div class="tag-row">${d.services.slice(0, limit).map(t => `<span class="tag">${t}</span>`).join("")}</div><div class="icon-bar">${ic}</div>${ageBlock}${cta}<div class="reg-id">ID ${d.id}</div>`;
    fragment.appendChild(card);
  });
  wrap.appendChild(fragment);
}
function updateCityList(arr) { const set = new Set(arr.map(d => d.city)); const dl = $("#city-list"); dl.innerHTML = ""; set.forEach(c => { const o = document.createElement("option"); o.value = c; dl.appendChild(o); }); }
const $ = q => document.querySelector(q);
async function init() {
  buildTierFilter(); buildCategoryMaster(); $("#card-container").innerHTML = '<p>Зареждане...</p>';
  $("#search-text").addEventListener("input", debounce(e => { searchTerm = e.target.value.toLowerCase(); render(); }, 250));
  $("#city-search").addEventListener("input", debounce(e => { cityTerm = e.target.value.toLowerCase().trim(); render(); }, 250));
  $("#age-from").addEventListener("input", debounce(e => { ageFrom = e.target.value ? +e.target.value : null; render(); }, 250));
  $("#age-to").addEventListener("input", debounce(e => { ageTo = e.target.value ? +e.target.value : null; render(); }, 250));
  $("#sop-toggle").addEventListener("change", e => { sopFilter = e.target.checked ? true : null; render(); });
  $("#online-toggle").addEventListener("change", e => { onlineFilter = e.target.checked; render(); });
  try {
    const cacheKey = 'companyData_v3'; /* Updated cache key */
    const cachedData = localStorage.getItem(cacheKey);
    if (cachedData) { data = JSON.parse(cachedData); render(); return; }
    const response = await fetch('https://gist.githubusercontent.com/RZhelevPhD/bf8e152174630da717829332ab2d1324/raw/41165e462ca01eef0fe8e8bc9bc572ad22084f83/data-cat-2112026.json', { headers: { 'Accept': 'application/json' } });
    if (!response.ok) throw new Error(`HTTP error! Status: ${response.status}`);
    data = await response.json(); localStorage.setItem(cacheKey, JSON.stringify(data)); render();
  } catch (error) { console.error("Error loading data:", error); $("#card-container").innerHTML = '<p>Грешка при зареждане на данните: ' + error.message + '</p>'; }
}
function chipToggle(e) { const chip = e.currentTarget; const { type, value } = chip.dataset; const state = active[type]; if (chip.classList.contains("include")) { state.include.delete(value); state.exclude.add(value); chip.classList.remove("include"); chip.classList.add("exclude"); } else if (chip.classList.contains("exclude")) { state.exclude.delete(value); chip.classList.remove("exclude"); } else { state.include.add(value); chip.classList.add("include"); } updateChipStates(); render(); }
function updateChipStates() { document.querySelectorAll('.filter-chip').forEach(ch => { const { type, value } = ch.dataset; const state = active[type]; ch.classList.toggle('include', state.include.has(value)); ch.classList.toggle('exclude', state.exclude.has(value)); }); }
document.addEventListener('DOMContentLoaded', init);
