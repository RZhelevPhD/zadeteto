<script>
const SWIPE_THRESHOLD = 80;
const savedItems = [];
const stack = document.getElementById('cardStack');
const dismissedSection = document.getElementById('dismissedSection');
let showDismissed = false;

function initSwipe(card) {
  let startX = 0, currentX = 0, isDragging = false;

  const isInteractive = e => e.target.closest('.zd-cta, .zd-contact-icon, .zd-expand-hint, .zd-expand, .zd-undo');

  function handleSwipeEnd(card) {
    if (currentX > SWIPE_THRESHOLD) {
      likeCard(card);
    } else if (currentX < -SWIPE_THRESHOLD) {
      dismissCard(card);
    } else {
      card.style.transform = '';
    }
    currentX = 0;
  }

  card.addEventListener('touchstart', e => {
    if (isInteractive(e) || card.classList.contains('dismissed')) return;
    startX = e.touches[0].clientX;
    isDragging = true;
    card.classList.add('swiping');
  }, { passive: true });

  card.addEventListener('touchmove', e => {
    if (!isDragging) return;
    currentX = e.touches[0].clientX - startX;
    card.style.transform = `translateX(${currentX}px) rotate(${currentX * 0.04}deg)`;
  }, { passive: true });

  card.addEventListener('touchend', () => {
    if (!isDragging) return;
    isDragging = false;
    card.classList.remove('swiping');
    handleSwipeEnd(card);
  });

  card.addEventListener('mousedown', e => {
    if (isInteractive(e) || card.classList.contains('dismissed')) return;
    startX = e.clientX; isDragging = true;
    card.classList.add('swiping');
    const onMove = ev => {
      if (!isDragging) return;
      currentX = ev.clientX - startX;
      card.style.transform = `translateX(${currentX}px) rotate(${currentX * 0.04}deg)`;
    };
    const onUp = () => {
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
      card.classList.remove('swiping');
      if (!isDragging) return;
      isDragging = false;
      handleSwipeEnd(card);
    };
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
  });
}

function likeCard(card) {
  card.style.transform = '';
  card.classList.add('liked');
  const img = card.querySelector('.zd-logo img');
  const name = card.querySelector('.zd-name').textContent;
  savedItems.push({ img: img ? img.src : '', name });
  updateSavedBar();
}

function dismissCard(card) {
  card.style.transform = '';
  card.classList.add('dismissed');
  card.classList.remove('expanded');

  // Animate to dismissed section
  setTimeout(() => {
    dismissedSection.appendChild(card);
    updateCounts();
  }, 350);
}

function undoDismiss(btn) {
  const card = btn.closest('.zd-card');
  card.classList.remove('dismissed');
  card.style.transform = '';
  stack.appendChild(card);
  updateCounts();
}

function updateCounts() {
  const activeCards = stack.querySelectorAll('.zd-card:not(.dismissed)').length;
  document.getElementById('count').textContent = activeCards;

  const dismissedCards = dismissedSection.querySelectorAll('.zd-card').length;
  document.getElementById('dismissedCount').textContent = dismissedCards;

  const toggle = document.getElementById('dismissedToggle');
  const label = document.getElementById('dismissedToggleLabel');
  if (dismissedCards > 0) {
    toggle.classList.add('has-items');
    label.textContent = `${dismissedCards} скрити`;
  } else {
    toggle.classList.remove('has-items');
    dismissedSection.classList.remove('visible');
    showDismissed = false;
    toggle.classList.remove('active');
  }
}

function toggleDismissed() {
  showDismissed = !showDismissed;
  const toggle = document.getElementById('dismissedToggle');
  toggle.classList.toggle('active', showDismissed);
  dismissedSection.classList.toggle('visible', showDismissed);
}

function updateSavedBar() {
  const bar = document.getElementById('savedBar');
  const avatars = document.getElementById('savedAvatars');
  const count = document.getElementById('savedCount');
  if (savedItems.length === 0) { bar.classList.remove('visible'); return; }
  bar.classList.add('visible');
  count.textContent = savedItems.length;
  avatars.innerHTML = savedItems.slice(-4).map(s =>
    `<div class="saved-avatar"><img src="${s.img}" alt="${s.name}"></div>`
  ).join('');
}

function toggleExpand(hint) {
  hint.closest('.zd-card').classList.toggle('expanded');
}

// Init
document.querySelectorAll('.zd-card').forEach(initSwipe);
document.querySelectorAll('.zd-cta, .zd-contact-icon').forEach(el => {
  el.addEventListener('click', e => e.stopPropagation());
});
</script>
