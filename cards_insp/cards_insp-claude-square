      </div>
      <div class="zd-expand-hint" onclick="toggleExpand(this)"><span>Детайли</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div>
    </div>
    <div class="zd-expand"><div class="zd-expand-inner">
